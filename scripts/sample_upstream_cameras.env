# Sample upstream camera config — shape expected by scripts/migrate_cameras_from_env.py
#
# Keys follow the pattern <PREFIX><CAMERA_ID>_<FIELD>, default prefix is "CAM"
# so CAM01_IP means camera_id="CAM01", field="ip_address".
#
# Supported field suffixes:
#   _NAME       human-readable label
#   _FLOOR      optional floor/zone grouping
#   _ZONE       optional link to zone_occupancy.zone_id
#   _IP         camera host (IPv4, IPv6, or DNS name) — required
#   _RTSP_PORT  optional, defaults to 554
#   _RTSP_PATH  optional, defaults to /Streaming/Channels/101 (Hikvision)
#   _USER       RTSP username
#   _PASS       RTSP password — encrypted on ingest
#   _ENABLED    true/false, defaults to true
#   _NOTES      free text
#
# Backwards compatibility: if your upstream already stores a full URL like
#   CAM01_RTSP=rtsp://admin:p%40ss@10.0.0.5:554/Streaming/Channels/101
# the migrator will parse it with urllib.parse.urlsplit() and decompose it
# into the fields above. Don't mix decomposed fields with _RTSP= for the same
# camera — the migrator will refuse rather than guess which one wins.

CAM01_NAME=B1 Entry Gate
CAM01_FLOOR=B1
CAM01_ZONE=B1-PARKING
CAM01_IP=10.0.0.5
CAM01_RTSP_PORT=554
CAM01_RTSP_PATH=/Streaming/Channels/101
CAM01_USER=admin
CAM01_PASS=hunter2
CAM01_ENABLED=true
CAM01_NOTES=Front-left corner, wide-angle

CAM02_NAME=B1 Exit Gate
CAM02_FLOOR=B1
CAM02_IP=10.0.0.6
CAM02_USER=admin
CAM02_PASS=hunter2

CAM03_NAME=B2 Ramp
CAM03_FLOOR=B2
CAM03_IP=10.0.0.7
CAM03_USER=operator
CAM03_PASS=p@ss/word#1
CAM03_ENABLED=true
