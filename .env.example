# ── SQL Server (shared by System 1) ──────────────────────────────────────────
# DB_DRIVER options:
#   "ODBC Driver 18 for SQL Server"  ← recommended on Windows / containers
#   "ODBC Driver 17 for SQL Server"  ← older Windows / Linux ODBC installs
#   "pymssql"                         ← FreeTDS-based fallback for macOS/Linux dev
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=damanat_pms

# When DB_TRUSTED_CONNECTION=True (Windows Auth), DB_USER and DB_PASSWORD
# are IGNORED — leave them as-is or blank. The connection uses the current
# Windows session's credentials.
DB_USER=sa
DB_PASSWORD=YourStrong!Pass1
DB_TRUSTED_CONNECTION=False

# ── Upstream system base URLs ─────────────────────────────────────────────────
SYSTEM1_BASE_URL=http://localhost:8080          # Damanat-PMS-AI
SYSTEM2_BASE_URL=http://localhost:8000          # Damanat-PMS-VideoAnalytics

# ── Gateway ───────────────────────────────────────────────────────────────────
GATEWAY_PORT=8001
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Camera credentials encryption (REQUIRED) ──────────────────────────────────
# Generate once and keep secret:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CAMERAS_ENCRYPTION_KEY=

# Internal token for /cameras/{id}/credentials and /cameras/internal/all (REQUIRED).
# Generate once and share with upstream consumers (e.g. VideoAnalytics):
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
CAMERAS_INTERNAL_TOKEN=

# ── Snapshots (PMS-AI shared volume) ──────────────────────────────────────────
# Path inside the gateway container where PMS-AI writes detection JPEGs.
# Mount the same volume PMS-AI writes to (read-only). When the directory
# exists, /snapshots is exposed as a StaticFiles mount and DTO snapshot_url
# values are rewritten from `detection_images/foo.jpg` → `/snapshots/foo.jpg`.
SNAPSHOTS_LOCAL_DIR=/app/detection_images
SNAPSHOTS_PUBLIC_BASE=http://localhost:8001

# ── Camera liveness monitor ───────────────────────────────────────────────────
# Toggle the background TCP poller. Disable for local dev when cameras are unreachable.
#CAMERA_MONITOR_ENABLED=true
#CAMERA_MONITOR_INTERVAL_SECONDS=60
#CAMERA_MONITOR_TCP_TIMEOUT_SECONDS=3.0
#CAMERA_MONITOR_CONCURRENCY=20
