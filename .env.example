# ── SQL Server (shared by System 1) ──────────────────────────────────────────
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_SERVER=localhost
DB_NAME=ParkingDB
DB_USER=sa
DB_PASSWORD=your_password_here
DB_TRUSTED_CONNECTION=False  # Set to True to use Windows Authentication (ignores user/pass)

# ── Upstream system base URLs ─────────────────────────────────────────────────
SYSTEM1_BASE_URL=http://localhost:8001          # Damanat-PMS-AI
SYSTEM2_BASE_URL=http://localhost:8002          # Damanat-PMS-VideoAnalytics

# ── Gateway ───────────────────────────────────────────────────────────────────
GATEWAY_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
